import { initializeApp } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-app.js";
import { getDatabase, ref, onValue } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSy...",
  databaseURL: "https://nexasmm-default-rtdb.firebaseio.com"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase(app);

let user = Telegram.WebApp.initDataUnsafe.user;

document.getElementById("name").innerText = user.first_name;

const balRef = ref(db, "users/" + user.id + "/web_balance");

onValue(balRef, (snap) => {
  document.getElementById("bal").innerText = snap.val() || 0;
});
